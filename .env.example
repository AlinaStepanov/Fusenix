# ════════════════════════════════════════════════════════════════════════════
# OpsBridge — backend environment variables
# Copy this file to .env and fill in your real credentials.
# docker compose up picks it up automatically via env_file:.
#
# ⚠️  SECURITY RULES — READ BEFORE EDITING:
#   1. This file is loaded ONLY by the backend container. Never add these keys
#      to the frontend build or expose them via VITE_* prefixes.
#   2. Vite auto-reads .env files in the project root during `npm run dev`.
#      Any variable you prefix with VITE_ will be BAKED INTO the JS bundle
#      and sent to every browser. Only put non-secret config in VITE_ vars.
#   3. .env is git-ignored. Never commit real credentials.
# ════════════════════════════════════════════════════════════════════════════

# ── AWS / CloudWatch ─────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Comma-separated CloudWatch log group names to query for errors
CW_LOG_GROUPS=/aws/lambda/my-api,/ecs/my-service,/var/log/app

# Optional: filter alarms by prefix (leave empty for all alarms)
CW_ALARM_PREFIX=prod-

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal access token (needs: repo, read:org, workflow)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list of repos to watch (format: owner/repo)
GITHUB_REPOS=myorg/api-service,myorg/frontend,myorg/infra

# ── AI analysis ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins the backend will accept cross-origin requests from.
# In production set this to your actual frontend URL, e.g. https://opsbridge.example.com
# Defaults to localhost dev origins when not set.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
