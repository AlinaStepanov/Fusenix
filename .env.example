# ════════════════════════════════════════════════════════════════════════════
# OpsBridge — environment variables
# Copy this file to .env and fill in your real credentials.
# docker compose up picks it up automatically via env_file.
#
# ⚠️  SECURITY RULES — READ BEFORE EDITING:
#   1. These variables are loaded ONLY by the backend. Never expose them to
#      the frontend via VITE_* prefixes — Vite bakes those into the JS bundle.
#   2. .env is git-ignored. Never commit real credentials.
# ════════════════════════════════════════════════════════════════════════════

# ── AWS / CloudWatch ─────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Comma-separated CloudWatch log group names to query for errors
CW_LOG_GROUPS=/aws/lambda/my-api,/ecs/my-service,/var/log/app

# Optional: filter alarms by prefix (leave empty for all alarms)
CW_ALARM_PREFIX=prod-

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal access token (needs: repo, read:org, workflow)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list of repos to watch (format: owner/repo)
GITHUB_REPOS=myorg/api-service,myorg/frontend,myorg/infra

# ── AI analysis ───────────────────────────────────────────────────────────────
# Select your AI provider. Supported values:
#   openrouter | openai | anthropic | ollama | azure_openai
#   groq | together | mistral | (any OpenAI-compatible via AI_BASE_URL)
AI_PROVIDER=openrouter

# Universal fallbacks — used when no provider-specific var is set below
# AI_API_KEY=
# AI_MODEL=
# AI_BASE_URL=   # override base URL for custom / self-hosted endpoints

# Fill in the block that matches your AI_PROVIDER; the rest are ignored.

# OpenRouter (200+ models, openrouter/auto picks the best available)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=openrouter/auto

# OpenAI
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ollama — local inference, no key needed; run `ollama serve` first
# AI_MODEL=llama3
# AI_BASE_URL=http://localhost:11434/v1   # change host if not local

# Azure OpenAI
# AZURE_OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-01

# Groq
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GROQ_MODEL=llama3-8b-8192

# Together AI
# TOGETHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TOGETHER_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1

# Mistral AI
# MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MISTRAL_MODEL=mistral-small-latest

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated origins the backend will accept cross-origin requests from.
# In production set this to your actual frontend URL.
# Defaults to localhost dev origins when not set.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
