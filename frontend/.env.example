# ════════════════════════════════════════════════════════════════════════════
# Fusenix — FRONTEND environment variables  (safe to set here)
#
# ⚠️  Any variable you put here MUST start with VITE_ and MUST NOT be a secret.
#     Vite bakes VITE_* values into the compiled JS bundle that every user
#     downloads. Secrets added here are immediately public.
#
# Backend secrets (AWS keys, tokens, API keys) go in the ROOT .env only.
# ════════════════════════════════════════════════════════════════════════════

# API base URL — leave empty to use relative URLs (proxied by nginx / Vite dev server).
# Override only if your backend runs on a different host, e.g.:
#   VITE_API_URL=https://api.fusenix.example.com
VITE_API_URL=
